<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <!-- Credentials are never committed — CI injects them via the env var
       NuGetPackageSourceCredentials_github (Username=actions;Password=$GITHUB_TOKEN). -->

  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github" value="https://nuget.pkg.github.com/Resurrection-Capsule/index.json" />
  </packageSources>

  <!-- Pin org packages to the org feed; everything else from nuget.org. Required by Central
       Package Management with multiple sources (NU1507) and prevents dependency confusion. -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github">
      <package pattern="RakNexus" />
      <package pattern="AssetData.Parser*" />
      <package pattern="ReCap.*" />
    </packageSource>
  </packageSourceMapping>

</configuration>
